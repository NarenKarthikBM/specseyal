# macOS
.DS_Store

# graphify output (regenerated per repo; never committed)
graphify-out/

# Python / node debris from extension tooling
__pycache__/
*.pyc
node_modules/

# spec-kit working state: active-feature pointer, transient/per-session (D45).
# The active feature is resolved from this at runtime; durable phase state lives
# only under specs/NNN/ (D32), so this is never committed.
.specify/feature.json

# workforce installer flock target (install.sh S06): a persistent, empty lock
# handle re-flocked by every reinstall — a runtime artifact, never meaningful state.
.specify/extensions.yml.lock

# rendered defense decks are derived build products, never the artifact of
# record (FR-014); SC-005 asserts git ls-files returns none.
specs/*/renders/

# ...and a rendered deck must never be tracked *regardless of path* (SC-005),
# not merely when it lands under renders/. The rule above is path-scoped, so it
# never covered a .pptx written into the council subtree by hand — which is how
# 008's defense deck was admitted by a council human-gate commit (I-34).
# deck-render itself never writes under council/ (FR-009), so any .pptx here is
# by definition hand-placed and derived. Guards the commit path that admitted it.
specs/*/council/defense-deck/*.pptx
